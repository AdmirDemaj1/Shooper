# Mobile App Environment Variables
# Copy to .env.local and fill in your values

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_API_ENV=dev

# Firebase Configuration
# Get these from Firebase Console > Project Settings
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=autoscout-dev.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=autoscout-dev
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=autoscout-dev.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:ios:abcdef1234567890

# Mapbox Token (for location picker)
# Get from https://account.mapbox.com/
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiYWRpZGVtYWoiLCJhIjoiY2t...

# Feature Flags
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true

# Development
EXPO_PUBLIC_LOG_LEVEL=debug
